# Optional shim configuration. All values can be overridden via environment
# variables of the same name when invoking the installer.
#
# CJV_VERSION    Pin to a specific tag (e.g. v0.2.0). When unset the shim
#                queries CJV_API_BASE_URL for the latest release.
# CJV_REPOSITORY GitHub "<owner>/<repo>" hosting the cjv binary releases.
# CJV_RELEASE_BASE_URL  Override the asset download base URL (defaults to
#                       https://github.com/<repo>/releases/download).
# CJV_API_BASE_URL      Override the GitHub API base URL used for the
#                       latest-tag lookup (defaults to https://api.github.com).
CJV_REPOSITORY=Zxilly/cjv
